APP_NAME=Sistem Pakar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

# Subtitle panjang di dashboard & halaman login (opsional)
APP_TAGLINE="Sistem Pakar Diagnosa Kerusakan Printer — metode Forward Chaining"

# Nomor teknisi untuk Call / WhatsApp (format: 628xxx tanpa +)
TEKNISI_PHONE=6281234567890
TEKNISI_NAME="Teknisi Berkah Andirra"
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Samakan dengan mjmscan-next (.env / .env.local): satu baris connection string Postgres (Neon).
# Contoh: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DB_CONNECTION=pgsql
DATABASE_URL=

SESSION_DRIVER=file
SESSION_LIFETIME=10080

# Sama seperti Next — dipakai seeder admin
ADMIN_EMAIL=admin@local.id
ADMIN_PASSWORD=admin123

# Email (pendaftaran akun — password dikirim ke email user)
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SCHEME=tls
MAIL_FROM_ADDRESS=
MAIL_FROM_NAME="${APP_NAME}"
