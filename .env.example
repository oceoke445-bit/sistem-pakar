APP_NAME=Sistem Pakar
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=Asia/Jakarta
APP_URL=http://localhost:8000

# Subtitle panjang di dashboard & halaman login (opsional)
APP_TAGLINE="Sistem Pakar Diagnosa Kerusakan Printer — metode Forward Chaining"
APP_FALLBACK_LOCALE=en

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Samakan dengan mjmscan-next (.env / .env.local): satu baris connection string Postgres (Neon).
# Contoh: postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require
DB_CONNECTION=pgsql
DATABASE_URL=

SESSION_DRIVER=file
SESSION_LIFETIME=10080

# Sama seperti Next — dipakai seeder admin
ADMIN_EMAIL=admin@local.id
ADMIN_PASSWORD=admin123
